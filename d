CREATE OR REPLACE VIEW HEALTH_METRICS AS

WITH DOMAIN_JOB_MAPPING AS
(
    SELECT
        DSE_HEALTH_DOMAIN.HEALTH_AREA_ID,
        DSE_HEALTH_DOMAIN.HEALTH_AREA_NAME,
        DSE_HEALTH_DOMAIN.DOMAIN_ID,
        DSE_HEALTH_DOMAIN.DOMAIN_NAME,

        JOB_MAPPING.VALUE:jobid::NUMBER AS JOBID,

        DSID_MAPPING.VALUE::VARCHAR AS CONFIGURED_DSID

    FROM DSE_HEALTH_DOMAIN,

    LATERAL FLATTEN
    (
        INPUT => DSE_HEALTH_DOMAIN.ASSOCIATED_JOBS
    ) JOB_MAPPING,

    LATERAL FLATTEN
    (
        INPUT => JOB_MAPPING.VALUE:dsids,
        OUTER => TRUE
    ) DSID_MAPPING
),

DOMAIN_JOB_DETAILS AS
(
    SELECT
        DOMAIN_JOB_MAPPING.HEALTH_AREA_ID,
        DOMAIN_JOB_MAPPING.HEALTH_AREA_NAME,
        DOMAIN_JOB_MAPPING.DOMAIN_ID,
        DOMAIN_JOB_MAPPING.DOMAIN_NAME,
        DOMAIN_JOB_MAPPING.JOBID,
        DOMAIN_JOB_MAPPING.CONFIGURED_DSID,
        DSE_JOB_CONFIG.JOBNAME
    FROM DOMAIN_JOB_MAPPING

    LEFT JOIN DSE_JOB_CONFIG
        ON DOMAIN_JOB_MAPPING.JOBID = DSE_JOB_CONFIG.JOBID
       AND DSE_JOB_CONFIG.ENVIRONMENT_ID = 1
),

LATEST_TEST_RESULTS AS
(
    SELECT
        DSE_TESTRESULTS.DSID,
        DSE_TESTRESULTS.JOBNAME,
        DSE_TESTRESULTS.EXECUTIONSTEP,
        DSE_TESTRESULTS.TESTCASEDESCRIPTION,
        DSE_TESTRESULTS.METRICRESULTS,
        DSE_TESTRESULTS.TESTSTATUS,
        DSE_TESTRESULTS.WEIGHTED_SCORE,
        DSE_TESTRESULTS.AVERAGE_SCORE,
        DSE_TESTRESULTS.RUNDATE,
        DSE_TESTRESULTS.RUNID,
        DSE_TESTRESULTS.ENVIRONMENT_ID,
        DSE_TESTRESULTS.ACTIVE_IND

    FROM DSE_TESTRESULTS

    WHERE DSE_TESTRESULTS.ENVIRONMENT_ID = 1
      AND COALESCE(DSE_TESTRESULTS.ACTIVE_IND, 'Y') = 'Y'

    QUALIFY DSE_TESTRESULTS.RUNID =
        MAX(DSE_TESTRESULTS.RUNID)
        OVER
        (
            PARTITION BY DSE_TESTRESULTS.JOBNAME
        )
)

SELECT
    DOMAIN_JOB_DETAILS.HEALTH_AREA_ID,
    DOMAIN_JOB_DETAILS.HEALTH_AREA_NAME,
    DOMAIN_JOB_DETAILS.DOMAIN_ID,
    DOMAIN_JOB_DETAILS.DOMAIN_NAME,

    NULL::VARCHAR AS USECASE_ID,

    LATEST_TEST_RESULTS.EXECUTIONSTEP::VARCHAR AS USECASE_NAME,

    LATEST_TEST_RESULTS.DSID::VARCHAR AS DSID,
    LATEST_TEST_RESULTS.TESTSTATUS,
    LATEST_TEST_RESULTS.WEIGHTED_SCORE,
    LATEST_TEST_RESULTS.AVERAGE_SCORE,
    LATEST_TEST_RESULTS.TESTCASEDESCRIPTION,
    LATEST_TEST_RESULTS.METRICRESULTS,
    LATEST_TEST_RESULTS.RUNDATE::VARCHAR AS RUNDATE

FROM DOMAIN_JOB_DETAILS

LEFT JOIN LATEST_TEST_RESULTS
    ON DOMAIN_JOB_DETAILS.JOBNAME =
       LATEST_TEST_RESULTS.JOBNAME

   AND
   (
       DOMAIN_JOB_DETAILS.CONFIGURED_DSID IS NULL

       OR DOMAIN_JOB_DETAILS.CONFIGURED_DSID =
          LATEST_TEST_RESULTS.DSID::VARCHAR
   );
