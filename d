CREATE OR REPLACE VIEW HEALTH_METRICS_DETAIL AS

WITH CONFIGURATION AS
(
    SELECT
        DSE_HEALTH_DOMAIN.HEALTH_AREA_ID,
        DSE_HEALTH_DOMAIN.HEALTH_AREA_NAME,
        DSE_HEALTH_DOMAIN.DOMAIN_ID,
        DSE_HEALTH_DOMAIN.DOMAIN_NAME,

        COALESCE(
            TRY_TO_NUMBER(
                DSE_HEALTH_DOMAIN.ASSOCIATED_JOBS:domain_weight
            ),
            1
        ) AS DOMAIN_WEIGHT,

        USECASE_CONFIG.VALUE:usecase_id::VARCHAR
            AS USECASE_ID,

        USECASE_CONFIG.VALUE:usecase_name::VARCHAR
            AS USECASE_NAME,

        COALESCE(
            TRY_TO_NUMBER(
                USECASE_CONFIG.VALUE:usecase_weight
            ),
            1
        ) AS USECASE_WEIGHT,

        TRY_TO_NUMBER(
            JOB_CONFIG.VALUE:jobid
        ) AS JOBID,

        TEST_CONFIG.VALUE:dsid::VARCHAR
            AS DSID,

        COALESCE(
            TRY_TO_NUMBER(
                TEST_CONFIG.VALUE:weight
            ),
            1
        ) AS DSID_WEIGHT,

        COALESCE(
            TRY_TO_BOOLEAN(
                TEST_CONFIG.VALUE:critical
            ),
            FALSE
        ) AS CRITICAL_IND

    FROM DSE_HEALTH_DOMAIN

    CROSS JOIN LATERAL FLATTEN
    (
        INPUT => DSE_HEALTH_DOMAIN.ASSOCIATED_JOBS:usecases
    ) USECASE_CONFIG

    CROSS JOIN LATERAL FLATTEN
    (
        INPUT => USECASE_CONFIG.VALUE:jobs
    ) JOB_CONFIG

    CROSS JOIN LATERAL FLATTEN
    (
        INPUT => JOB_CONFIG.VALUE:tests
    ) TEST_CONFIG

    WHERE DSE_HEALTH_DOMAIN.ASSOCIATED_JOBS IS NOT NULL
),

JOB_CONFIGURATION AS
(
    SELECT
        DSE_JOB_CONFIG.JOBID,
        DSE_JOB_CONFIG.JOBNAME

    FROM DSE_JOB_CONFIG

    WHERE DSE_JOB_CONFIG.ENVIRONMENT_ID = 1

    QUALIFY ROW_NUMBER() OVER
    (
        PARTITION BY DSE_JOB_CONFIG.JOBID
        ORDER BY DSE_JOB_CONFIG.JOBNAME
    ) = 1
),

CONFIGURATION_WITH_JOB AS
(
    SELECT
        CONFIGURATION.HEALTH_AREA_ID,
        CONFIGURATION.HEALTH_AREA_NAME,
        CONFIGURATION.DOMAIN_ID,
        CONFIGURATION.DOMAIN_NAME,
        CONFIGURATION.DOMAIN_WEIGHT,
        CONFIGURATION.USECASE_ID,
        CONFIGURATION.USECASE_NAME,
        CONFIGURATION.USECASE_WEIGHT,
        CONFIGURATION.JOBID,
        JOB_CONFIGURATION.JOBNAME,
        CONFIGURATION.DSID,
        CONFIGURATION.DSID_WEIGHT,
        CONFIGURATION.CRITICAL_IND

    FROM CONFIGURATION

    LEFT JOIN JOB_CONFIGURATION
        ON CONFIGURATION.JOBID =
           JOB_CONFIGURATION.JOBID
),

LATEST_JOB_RUN AS
(
    SELECT
        DSE_TESTRESULTS.JOBNAME,
        MAX(DSE_TESTRESULTS.RUNID) AS RUNID

    FROM DSE_TESTRESULTS

    WHERE DSE_TESTRESULTS.ENVIRONMENT_ID = 1
      AND COALESCE(DSE_TESTRESULTS.ACT_IND, 'Y') = 'Y'

    GROUP BY
        DSE_TESTRESULTS.JOBNAME
),

LATEST_TEST_RESULTS AS
(
    SELECT
        DSE_TESTRESULTS.JOBNAME,
        DSE_TESTRESULTS.DSID::VARCHAR AS DSID,
        DSE_TESTRESULTS.RUNID,
        DSE_TESTRESULTS.RUNDATE,
        UPPER(TRIM(DSE_TESTRESULTS.TESTSTATUS))
            AS TESTSTATUS,
        DSE_TESTRESULTS.TESTCASEDESCRIPTION,
        DSE_TESTRESULTS.METRICRESULTS

    FROM DSE_TESTRESULTS

    INNER JOIN LATEST_JOB_RUN
        ON DSE_TESTRESULTS.JOBNAME =
           LATEST_JOB_RUN.JOBNAME

       AND DSE_TESTRESULTS.RUNID =
           LATEST_JOB_RUN.RUNID

    WHERE DSE_TESTRESULTS.ENVIRONMENT_ID = 1
      AND COALESCE(DSE_TESTRESULTS.ACT_IND, 'Y') = 'Y'

    QUALIFY ROW_NUMBER() OVER
    (
        PARTITION BY
            DSE_TESTRESULTS.JOBNAME,
            DSE_TESTRESULTS.DSID

        ORDER BY
            DSE_TESTRESULTS.RUNDATE DESC NULLS LAST,
            DSE_TESTRESULTS.RUNID DESC
    ) = 1
),

DSID_RESULTS AS
(
    SELECT
        CONFIGURATION_WITH_JOB.HEALTH_AREA_ID,
        CONFIGURATION_WITH_JOB.HEALTH_AREA_NAME,
        CONFIGURATION_WITH_JOB.DOMAIN_ID,
        CONFIGURATION_WITH_JOB.DOMAIN_NAME,
        CONFIGURATION_WITH_JOB.DOMAIN_WEIGHT,
        CONFIGURATION_WITH_JOB.USECASE_ID,
        CONFIGURATION_WITH_JOB.USECASE_NAME,
        CONFIGURATION_WITH_JOB.USECASE_WEIGHT,
        CONFIGURATION_WITH_JOB.JOBID,
        CONFIGURATION_WITH_JOB.JOBNAME,
        CONFIGURATION_WITH_JOB.DSID,
        CONFIGURATION_WITH_JOB.DSID_WEIGHT,
        CONFIGURATION_WITH_JOB.CRITICAL_IND,

        COALESCE(
            LATEST_TEST_RESULTS.TESTSTATUS,
            ''
        ) AS TESTSTATUS,

        CASE
            WHEN LATEST_TEST_RESULTS.TESTSTATUS = 'PASS'
                THEN 100

            WHEN LATEST_TEST_RESULTS.TESTSTATUS = 'WARNING'
                THEN 50

            WHEN LATEST_TEST_RESULTS.TESTSTATUS = 'FAIL'
                THEN 0

            ELSE 0
        END AS DSID_SCORE,

        LATEST_TEST_RESULTS.TESTCASEDESCRIPTION,
        LATEST_TEST_RESULTS.METRICRESULTS,
        LATEST_TEST_RESULTS.RUNDATE,
        LATEST_TEST_RESULTS.RUNID

    FROM CONFIGURATION_WITH_JOB

    LEFT JOIN LATEST_TEST_RESULTS
        ON CONFIGURATION_WITH_JOB.JOBNAME =
           LATEST_TEST_RESULTS.JOBNAME

       AND CONFIGURATION_WITH_JOB.DSID =
           LATEST_TEST_RESULTS.DSID
),

DSID_WITH_USECASE_SCORE AS
(
    SELECT
        DSID_RESULTS.HEALTH_AREA_ID,
        DSID_RESULTS.HEALTH_AREA_NAME,
        DSID_RESULTS.DOMAIN_ID,
        DSID_RESULTS.DOMAIN_NAME,
        DSID_RESULTS.DOMAIN_WEIGHT,
        DSID_RESULTS.USECASE_ID,
        DSID_RESULTS.USECASE_NAME,
        DSID_RESULTS.USECASE_WEIGHT,
        DSID_RESULTS.JOBID,
        DSID_RESULTS.JOBNAME,
        DSID_RESULTS.DSID,
        DSID_RESULTS.DSID_WEIGHT,
        DSID_RESULTS.CRITICAL_IND,
        DSID_RESULTS.TESTSTATUS,

        DSID_RESULTS.DSID_SCORE
            AS WEIGHTED_SCORE,

        ROUND(
            SUM(
                DSID_RESULTS.DSID_SCORE *
                DSID_RESULTS.DSID_WEIGHT
            ) OVER
            (
                PARTITION BY
                    DSID_RESULTS.HEALTH_AREA_ID,
                    DSID_RESULTS.DOMAIN_ID,
                    DSID_RESULTS.USECASE_ID
            )
            /
            NULLIF(
                SUM(
                    DSID_RESULTS.DSID_WEIGHT
                ) OVER
                (
                    PARTITION BY
                        DSID_RESULTS.HEALTH_AREA_ID,
                        DSID_RESULTS.DOMAIN_ID,
                        DSID_RESULTS.USECASE_ID
                ),
                0
            ),
            2
        ) AS AVERAGE_SCORE,

        DSID_RESULTS.TESTCASEDESCRIPTION,
        DSID_RESULTS.METRICRESULTS,
        DSID_RESULTS.RUNDATE,
        DSID_RESULTS.RUNID

    FROM DSID_RESULTS
),

USECASE_SCORES AS
(
    SELECT DISTINCT
        DSID_WITH_USECASE_SCORE.HEALTH_AREA_ID,
        DSID_WITH_USECASE_SCORE.HEALTH_AREA_NAME,
        DSID_WITH_USECASE_SCORE.DOMAIN_ID,
        DSID_WITH_USECASE_SCORE.DOMAIN_NAME,
        DSID_WITH_USECASE_SCORE.DOMAIN_WEIGHT,
        DSID_WITH_USECASE_SCORE.USECASE_ID,
        DSID_WITH_USECASE_SCORE.USECASE_NAME,
        DSID_WITH_USECASE_SCORE.USECASE_WEIGHT,
        DSID_WITH_USECASE_SCORE.AVERAGE_SCORE

    FROM DSID_WITH_USECASE_SCORE
),

DOMAIN_SCORES AS
(
    SELECT
        USECASE_SCORES.HEALTH_AREA_ID,
        USECASE_SCORES.HEALTH_AREA_NAME,
        USECASE_SCORES.DOMAIN_ID,
        USECASE_SCORES.DOMAIN_NAME,

        MAX(
            USECASE_SCORES.DOMAIN_WEIGHT
        ) AS DOMAIN_WEIGHT,

        ROUND(
            SUM(
                USECASE_SCORES.AVERAGE_SCORE *
                USECASE_SCORES.USECASE_WEIGHT
            )
            /
            NULLIF(
                SUM(
                    USECASE_SCORES.USECASE_WEIGHT
                ),
                0
            ),
            2
        ) AS DOMAIN_SCORE

    FROM USECASE_SCORES

    GROUP BY
        USECASE_SCORES.HEALTH_AREA_ID,
        USECASE_SCORES.HEALTH_AREA_NAME,
        USECASE_SCORES.DOMAIN_ID,
        USECASE_SCORES.DOMAIN_NAME
),

HEALTH_AREA_SCORES AS
(
    SELECT
        DOMAIN_SCORES.HEALTH_AREA_ID,
        DOMAIN_SCORES.HEALTH_AREA_NAME,

        ROUND(
            SUM(
                DOMAIN_SCORES.DOMAIN_SCORE *
                DOMAIN_SCORES.DOMAIN_WEIGHT
            )
            /
            NULLIF(
                SUM(
                    DOMAIN_SCORES.DOMAIN_WEIGHT
                ),
                0
            ),
            2
        ) AS HEALTH_AREA_SCORE

    FROM DOMAIN_SCORES

    GROUP BY
        DOMAIN_SCORES.HEALTH_AREA_ID,
        DOMAIN_SCORES.HEALTH_AREA_NAME
),

HEALTH_METRIC_SCORE AS
(
    SELECT
        ROUND(
            AVG(
                HEALTH_AREA_SCORES.HEALTH_AREA_SCORE
            ),
            2
        ) AS OVERALL_SCORE

    FROM HEALTH_AREA_SCORES
)

SELECT
    COALESCE(
        DSID_WITH_USECASE_SCORE.HEALTH_AREA_ID::VARCHAR,
        ''
    ) AS HEALTH_AREA_ID,

    COALESCE(
        DSID_WITH_USECASE_SCORE.HEALTH_AREA_NAME,
        ''
    ) AS HEALTH_AREA_NAME,

    COALESCE(
        DSID_WITH_USECASE_SCORE.DOMAIN_ID::VARCHAR,
        ''
    ) AS DOMAIN_ID,

    COALESCE(
        DSID_WITH_USECASE_SCORE.DOMAIN_NAME,
        ''
    ) AS DOMAIN_NAME,

    COALESCE(
        DSID_WITH_USECASE_SCORE.USECASE_ID,
        ''
    ) AS USECASE_ID,

    COALESCE(
        DSID_WITH_USECASE_SCORE.USECASE_NAME,
        ''
    ) AS USECASE_NAME,

    COALESCE(
        DSID_WITH_USECASE_SCORE.DSID::VARCHAR,
        ''
    ) AS DSID,

    COALESCE(
        DSID_WITH_USECASE_SCORE.TESTSTATUS,
        ''
    ) AS TESTSTATUS,

    COALESCE(
        DSID_WITH_USECASE_SCORE.WEIGHTED_SCORE,
        0
    ) AS WEIGHTED_SCORE,

    COALESCE(
        DSID_WITH_USECASE_SCORE.AVERAGE_SCORE,
        0
    ) AS AVERAGE_SCORE,

    COALESCE(
        DOMAIN_SCORES.DOMAIN_SCORE,
        0
    ) AS DOMAIN_SCORE,

    COALESCE(
        HEALTH_AREA_SCORES.HEALTH_AREA_SCORE,
        0
    ) AS HEALTH_AREA_SCORE,

    COALESCE(
        HEALTH_METRIC_SCORE.OVERALL_SCORE,
        0
    ) AS OVERALL_SCORE,

    COALESCE(
        DSID_WITH_USECASE_SCORE.TESTCASEDESCRIPTION,
        ''
    ) AS TESTCASEDESCRIPTION,

    COALESCE(
        DSID_WITH_USECASE_SCORE.METRICRESULTS::VARCHAR,
        ''
    ) AS METRICRESULTS,

    COALESCE(
        TO_VARCHAR(
            DSID_WITH_USECASE_SCORE.RUNDATE
        ),
        ''
    ) AS RUNDATE

FROM DSID_WITH_USECASE_SCORE

LEFT JOIN DOMAIN_SCORES
    ON DSID_WITH_USECASE_SCORE.HEALTH_AREA_ID =
       DOMAIN_SCORES.HEALTH_AREA_ID

   AND DSID_WITH_USECASE_SCORE.DOMAIN_ID =
       DOMAIN_SCORES.DOMAIN_ID

LEFT JOIN HEALTH_AREA_SCORES
    ON DSID_WITH_USECASE_SCORE.HEALTH_AREA_ID =
       HEALTH_AREA_SCORES.HEALTH_AREA_ID

CROSS JOIN HEALTH_METRIC_SCORE;
