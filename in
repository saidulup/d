create or replace temporary table tmp_fltn as
select
    p.JOBNAME,
    p.EXECUTIONSTEP,
    p.ENVIRONMENT_ID,
    p.TESTCASEDESCRIPTION,
    nvl(p.FrequencyCounter,0) as FrequencyCounter,
    p.rundate,
    p.insertTimestamp,
    p.RUNID,
    p.ACTV_IND,
    p.TOTALRUNTIME,
    p.SQLRUNTIME,
    f1.seq,
    f1.key,
    f1.value::varchar as rslt
from TMP_PRIOR_TESTRESULTS p,
     lateral flatten(input => p.METRICRESULTS) f,
     lateral flatten(input => f.value) f1;
