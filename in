create or replace temporary table TMP_PRIOR_TESTRESULTS as
select *
from DSE_TESTRESULTS
where DSID = :DSID
  and ENVIRONMENT_ID = :v_ENVIRONMENT_ID
  and RUNID = :v_MAX_RUNID
  and ACTV_IND = 'Y'
qualify row_number() over (
    partition by DSID, ENVIRONMENT_ID, RUNID, JOBNAME, EXECUTIONSTEP, TESTCASEDESCRIPTION
    order by INSERTTIMESTAMP desc
) = 1;
